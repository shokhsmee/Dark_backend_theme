<templates id="template" xml:space="preserve">
    <!--  Apps Menu Button Override  -->
    <t t-inherit="web.NavBar.AppsMenu" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('o_navbar_apps_menu')]" position="replace">
            <t t-if="!isScopedApp">
                <button data-hotkey="h" title="Home Menu"
                        t-on-click="_onClickMenusPanel"
                        style="background-color: transparent; border: transparent; padding: 5px 10px;">
                    <i class="bi bi-arrow-left"
                       style="font-size: 20px; color: var(--oil-primary) !important;"/>
                </button>
            </t>
        </xpath>
    </t>
</templates>
